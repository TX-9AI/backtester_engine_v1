# =============================================================================
# .gitignore — backtester_engine_v1
# v1.0 — 2026-06-28 — Initial gitignore
# =============================================================================

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
credentials.py
*.pem
*.key
*.env
.env.*

# ── Runtime data — generated locally, not versioned ──────────────────────────
data/cache/
data/backtest_results.db
data/*.db
data/*.db-shm
data/*.db-wal
reports/output/
*.log
*.log.*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Deployment artifacts ──────────────────────────────────────────────────────
*.tar.gz
*.zip
*.bat
